      "social_handles": {}
    },
    {
      "id": "mike-moore-store",
      "name": "Mike Moore Store",
      "url": "https://shop.mikemoore.com",
      "tagline": "Teaching resources and merch",
      "template_family": "social/product-promo",
      "social_handles": {}
    }
  ],
  "voice": {
    "attributes": ["teaching-forward", "family-friendly", "hopeful", "clear", "Word-centered"],
    "do": [
      "Lead with scripture and practical application",
      "Use accessible language for Birmingham community",
      "Highlight movement and campus life (The Bridge)",
      "Invite story submission and volunteer paths",
      "Reference 'The Word of God is the Answer' legacy appropriately"
    ],
    "dont": [
      "Use clipart or low-res imagery",
      "Insider jargon without explanation",
      "Political endorsements",
      "Low-effort duplicate designs outside brand kit"
    ],
    "seeker_first": true
  },
  "story": {
    "model": "movement-institution",
    "pastor_face_ratio_max_30d": 0.5,
    "story_submission_url": "https://www.faithchapel.net/stories",
