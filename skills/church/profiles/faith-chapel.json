      "/stories",
      "/groups",
      "/volunteer",
      "/waystohelp",
      "/family",
      "The Bridge community events"
    ],
    "values": [
      "Grow through God's Word",
      "Reflect Jesus in every area of life",
      "Movement beyond Sunday",
      "Community at The Bridge",
      "Generational faithfulness"
    ]
  },
