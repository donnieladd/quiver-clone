    "tagline": "We're more than a church — we're a movement.",
    "tier": "institutional-premium",
    "logo_variants": ["primary", "reversed", "submark", "social_avatar"],
    "forbidden": [
      "clipart",
      "low_resolution_photos",
      "off_palette_colors",
      "unapproved_fonts",
      "logo_distortion"
    ],
    "photography": "High-quality stock or original only; no clipart; family-friendly; diverse congregation representation.",
    "fonts": {
      "primary": "Brand book primary (see hub)",
      "secondary": "Brand book secondary (see hub)",
      "display": "Series title treatment only"
    },
    "colors": {
      "primary": "See Brand Quick Reference Guide",
      "secondary": "See Brand Quick Reference Guide",
      "accent": "Series override only with comms approval",
      "neutral": "Brand neutrals per quick reference"
    }
  },
  "sub_brands": [
    {
      "id": "the-bridge",
      "name": "The Bridge",
