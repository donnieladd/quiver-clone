  "strategy": {
    "mission": "Transforming lives through the Word of God.",
    "vision": "We're more than a church — we're a movement.",
    "values": ["Word-centered", "Family", "Excellence", "Community", "Movement"],
    "positioning": "Institutional premium — Birmingham movement with campus community hub (The Bridge).",
    "audiences": [
      { "id": "member", "name": "Member", "description": "Active congregation and volunteers" },
      { "id": "seeker", "name": "Seeker", "description": "Exploring faith, first-time visitors" },
      { "id": "leader", "name": "Leader", "description": "Staff and ministry leads using brand hub" }
    ]
  },
  "logos": {
    "variants": [
      { "id": "primary", "path": "assets/logos/faith-chapel-primary.svg", "min_width_px": 120, "clear_space_ratio": 0.25, "backgrounds": ["light"] },
      { "id": "reversed", "path": "assets/logos/faith-chapel-reversed.svg", "min_width_px": 120, "clear_space_ratio": 0.25, "backgrounds": ["dark", "photo"] },
      { "id": "submark", "path": "assets/logos/faith-chapel-submark.svg", "min_width_px": 32, "clear_space_ratio": 0.2, "backgrounds": ["light", "dark"] }
    ],
    "forbidden": ["stretch", "rotate", "drop-shadow-on-logo", "clipart-lockup"]
